{
  "name": "aws-archview",
  "private": true,
  "version": "0.1.13",
  "type": "module",
  "main": "electron/main.cjs",
  "author": {
    "name": "AWS ArchView Maintainers",
    "email": "maintainers@aws-archview.local"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "electron:start": "electron .",
    "electron:build": "npm run build && electron-builder build"
  },
  "dependencies": {
    "@cloudscape-design/components": "^3.0.1314",
    "@cloudscape-design/global-styles": "^1.0.60",
    "@xyflow/react": "^12.11.0",
    "elkjs": "^0.11.1",
    "html-to-image": "^1.11.13",
    "js-yaml": "^4.2.0",
    "jspdf": "^4.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vite-plugin-svgr": "^5.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^3.0.0"
  },
  "build": {
    "appId": "com.aws-archview.app",
    "productName": "AWS ArchView",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/**/*",
      "electron/main.cjs"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
